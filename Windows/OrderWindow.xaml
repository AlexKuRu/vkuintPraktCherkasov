<Window x:Class="Chem.Windows.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chem.Windows"
        mc:Ignorable="d"
        Title="OrderWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="15"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
        </Grid.RowDefinitions>


        <StackPanel Orientation="Horizontal">
            <Image Source="/Resources/icon.png" HorizontalAlignment="Left"
                   Width="40" Height="40" Margin="0,0,10,0"/>
            <StackPanel>
                <TextBlock Text="CleanStore" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="Список товаров"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Column="1" HorizontalAlignment="Right" FontWeight="Bold" x:Name="UserInfoLabel"
               FontSize="14" Margin="0,10,10,0">
        Роль: <Run Text="{Binding Role}"></Run>
        </TextBlock>

        <ListView Grid.Row="2" Name="LviewOrderProduct">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1700"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <DockPanel LastChildFill="True">
                                <StackPanel Orientation="Vertical">


                                    <StackPanel Orientation="Vertical">
                                        <TextBlock FontFamily="Times New Roman" FontWeight="Bold"
                                               FontSize="20"
                                               DockPanel.Dock="Right"
                                               HorizontalAlignment="Right"
                                               Width="250">
                                        <Run Text="Дата доставки: " />
                                        <Run Text="{Binding DataDelivery}"></Run>
                                        </TextBlock>

                                        <TextBlock FontFamily="Times New Roman"
                                               DockPanel.Dock="Left"
                                               HorizontalAlignment="Left"
                                               Width="250"
                                               FontSize="18">
                                        <Run Text="Статус заказа: " />
                                        <Run Text="{Binding Status}"></Run>
                                        </TextBlock>

                                        <TextBlock FontFamily="Times New Roman"
                                               DockPanel.Dock="Left"
                                               HorizontalAlignment="Left"
                                               Width="800"
                                               FontSize="18">
                                        <Run Text="Адрес пункта: " />
                                        <Run Text="{Binding DeliveryAdress.NameAdress}"></Run>
                                        </TextBlock>

                                        <TextBlock FontFamily="Times New Roman"
                                               DockPanel.Dock="Left"
                                               HorizontalAlignment="Left"
                                               Width="600"
                                               FontSize="18">
                                        <Run Text="Дата заказа: " />
                                        <Run Text="{Binding DataOrder}"></Run>
                                        </TextBlock>

                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Удалить"
                                                Name="DelOrder"
                                                FontFamily="Times New Roman"
                                                FontSize="20"
                                                Background="#00FA9A"
                                                Margin="7"
                                                Height="30"
                                                Width="183">
                                            </Button>

                                            <Button Content="Редактировать"
                                                Name="EditOrder"
                                                FontFamily="Times New Roman"
                                                FontSize="20"
                                                Background="#00FA9A"
                                                Margin="7"
                                                Height="30"
                                                Width="183">
                                            </Button>
                                        </StackPanel>

                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
        <Button Grid.Row="4"
            Visibility="{Binding Control}"
            HorizontalAlignment="Right"
            Name="BtnOrderAdd"
            Margin="5"
            Content="Добавить"
            FontFamily="Times New Roman"
            FontSize="22"
            Background="#00FA9A"
            Height="30"
            Width="183">
        </Button>

    </Grid>
</Window>
