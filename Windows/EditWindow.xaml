<Window x:Class="Chem.Windows.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chem.Windows"
        mc:Ignorable="d"
        Title="EditWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        

        <!-- Наименование -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Наименование:" VerticalAlignment="Center"/>
        <TextBox x:Name="tbProductName" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <!-- Категория -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Категория:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbCategory" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"
                  DisplayMemberPath="CategoryName" SelectedValuePath="Id"/>

        <!-- Описание -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Описание:" VerticalAlignment="Top"/>
        <TextBox x:Name="tbDescription" Grid.Row="2" Grid.Column="1" Margin="5" Height="80" 
                 TextWrapping="Wrap" AcceptsReturn="True"/>

        <!-- Производитель -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Производитель:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbManufacturer" Grid.Row="3" Grid.Column="1" Margin="5" Height="30"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <!-- Поставщик -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Поставщик:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbSuplier" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <!-- Остаток -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Остаток:" VerticalAlignment="Center"/>
        <TextBox x:Name="tbQuantity" Grid.Row="5" Grid.Column="1" Margin="5" Height="30"/>

        <!-- Скидка % -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Скидка %:" VerticalAlignment="Center"/>
        <TextBox x:Name="tbDiscount" Grid.Row="6" Grid.Column="1" Margin="5" Height="30"/>

        <!-- Изображение (опционально) -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Изображение:" VerticalAlignment="Top"/>
        <StackPanel Grid.Row="7" Grid.Column="1" Margin="5">
            <Image x:Name="imgProduct" Width="150" Height="100" Stretch="UniformToFill"/>
            <Button Content="Выбрать изображение" Click="BtnSelectImage_Click" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,10">
            <Button x:Name="BtnSave" Content="Сохранить" Width="90" Height="30" Margin="5" 
                    Click="BtnSave_Click" Background="#4CAF50" Foreground="White"/>
            <Button x:Name="BtnDelete" Content="Удалить" Width="90" Height="30" Margin="5"
                    Click="BtnDelete_Click" Background="#F44336" Foreground="White"/>
            <Button x:Name="BtnCancel" Content="Отмена" Width="90" Height="30" Margin="5"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
