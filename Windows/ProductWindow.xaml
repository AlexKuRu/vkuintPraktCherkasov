<Window x:Class="Chem.Windows.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chem.Windows"
        mc:Ignorable="d"
        Background="#d9f2f8"
        Title="Товары" Height="550" Width="900" WindowStartupLocation="CenterScreen">
    
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Source="/Resources/icon.png"
                   Width="40" Height="40" Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="CleanStore" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Список товаров"/>
                    <TextBlock x:Name="tbRole"></TextBlock>
                </StackPanel>
                

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="tbUserInfo"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,10,0"/>
                    <Button Content="Назад" Width="90" Click="BtnBack_Click" Foreground="White" Background="#1b4965">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="12" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="dgProducts"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single">

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Фото" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Width="100" Height="60" Stretch="UniformToFill"
                                       Source="/Resources/png-transparent-chemistry-lab-experiment-science-flask-glass-bottle-equipment-liquid-research.png"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="220"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="220"/>
                        <DataGridTextColumn Header="Остаток" Binding="{Binding Quantity}" Width="80"/>
                        <DataGridTextColumn Header="Скидка %" Binding="{Binding Discount}" Width="80"/>

                        <!-- Цена: старая (красная зачеркнутая) + новая -->
                        <DataGridTemplateColumn Header="Цена" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="tbOldPrice"
                                               Text="{Binding Price}"
                                               Foreground="Red"
                                               TextDecorations="Strikethrough"
                                               Margin="0,0,6,0"
                                               Visibility="Collapsed"/>

                                        <TextBlock x:Name="tbNewPrice"
                                               Text="{Binding Price}"
                                               Foreground="Black"/>
                                    </StackPanel>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding HasDiscount}" Value="False">
                                            <Setter TargetName="tbOldPrice" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="tbNewPrice" Property="Text" Value="{Binding Price}"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                            <Setter TargetName="tbOldPrice" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="tbNewPrice" Property="Text" Value="{Binding DiscountedPrice}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Margin="0,10,0,0" VerticalAlignment="Bottom">
                    <StackPanel x:Name="panelAdminButtons" Orientation="Horizontal" HorizontalAlignment="Right" >
                        <Button x:Name="BtnAdd" Content="Добавить" Width="110" Click="BtnAdd_Click" Margin="5" Foreground="White" Background="#1b4965">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="BtnEdit" Content="Редактировать" Width="130" Click="BtnEdit_Click" Margin="5" Foreground="White" Background="#1b4965">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="BtnDelete" Content="Удалить" Width="110" Click="BtnDelete_Click" Margin="5" Foreground="White" Background="#1b4965">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="tbCount" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
