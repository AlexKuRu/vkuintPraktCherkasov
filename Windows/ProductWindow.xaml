<Window x:Class="Chem.Windows.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chem.Windows"
        mc:Ignorable="d"
        Title="ProductWindow" Height="550" Width="1100" WindowStartupLocation="CenterScreen">
    
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Source="/Resources/icon.png"
                   Width="40" Height="40" Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="CleanShop" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Список товаров"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="tbUserInfo"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,10,0"/>
                    <Button Content="Назад" Width="90" Click="BtnBack_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- панель поиска/фильтра/сортировки -->
                <Grid x:Name="panelControls" Grid.Row="0" Margin="0,0,0,10" >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="tbSearch"
                         Height="28"
                         Margin="0,0,10,0"
                         VerticalContentAlignment="Center"
                         ToolTip="Поиск"/>

                    <ComboBox x:Name="cbSupplier"
                          Grid.Column="1"
                          Height="28"
                          Margin="0,0,10,0"/>

                    <ComboBox x:Name="cbSort"
                          Grid.Column="2"
                          Height="28"/>
                </Grid>

                <!-- таблица товаров -->
                <DataGrid x:Name="dgProducts"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single">

                    <DataGrid.Columns>
                        <!-- фото -->
                        <DataGridTemplateColumn Header="Фото" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Width="100" Height="60" Stretch="UniformToFill"
                                       Source="{Binding Image}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="220"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding Category.CategoryName}" Width="140"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="220"/>
                        <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer.Name}" Width="140"/>
                        <DataGridTextColumn Header="Поставщик" Binding="{Binding Suplier.Name}" Width="140"/>
                        <DataGridTextColumn Header="Остаток" Binding="{Binding Quantity}" Width="80"/>
                        <DataGridTextColumn Header="Скидка %" Binding="{Binding Discount}" Width="80"/>

                        <!-- Цена: старая (красная зачеркнутая) + новая -->
                        <DataGridTemplateColumn Header="Цена" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <!-- контент -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="tbOldPrice"
                                               Text="{Binding Price}"
                                               Foreground="Red"
                                               TextDecorations="Strikethrough"
                                               Margin="0,0,6,0"
                                               Visibility="Collapsed"/>

                                        <TextBlock x:Name="tbNewPrice"
                                               Text="{Binding Price}"
                                               Foreground="Black"/>
                                    </StackPanel>

                                    <DataTemplate.Triggers>
                                        <!-- скидки нет -->
                                        <DataTrigger Binding="{Binding HasDiscount}" Value="False">
                                            <Setter TargetName="tbOldPrice" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="tbNewPrice" Property="Text" Value="{Binding Price}"/>
                                        </DataTrigger>

                                        <!-- скидка есть -->
                                        <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                            <Setter TargetName="tbOldPrice" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="tbNewPrice" Property="Text" Value="{Binding DiscountedPrice}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <StackPanel x:Name="panelAdminButtons"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Visibility="Collapsed">
                        <Button x:Name="BtnAdd" Content="Добавить" Width="110" Click="BtnAdd_Click"/>
                        <Button x:Name="BtnEdit" Content="Редактировать" Width="130" Click="BtnEdit_Click"/>
                        <Button x:Name="BtnDelete" Content="Удалить" Width="110" Click="BtnDelete_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="tbCount" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
